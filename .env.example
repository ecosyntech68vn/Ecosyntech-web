# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️ SECURITY WARNING / CẢNH BÁO BẢO MẬT ⚠️
# ═══════════════════════════════════════════════════════════════════════════════
# You MUST change JWT_SECRET before deploying to production!
# Bạn PHẢI thay đổi JWT_SECRET trước khi triển khai production!
#
# FAILURE TO DO SO WILL RESULT IN INSECURE SYSTEM
# VIỆC KHÔNG THAY ĐỔI SẼ KHIẾN HỆ THỐNG KHÔNG BẢO MẬT
# ═══════════════════════════════════════════════════════════════════════════════

# EcoSynTech IoT - Environment Configuration
# Copy to .env and configure

# ====================
# REQUIRED (Manual Input)
# ====================

# Server Configuration
PORT=3000
NODE_ENV=development

# Security (MUST CHANGE IN PRODUCTION / PHẢI THAY ĐỔI TRƯỚC PRODUCTION)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_EXPIRES_IN=7d

# ====================
# OPTIONAL (Auto-configured)
# ====================

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# MQTT Broker (optional, will skip if empty)
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=

# InfluxDB (optional, will skip if empty)
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=

# Database
DB_TYPE=sqlite
DB_PATH=./data/ecosyntech.db

# PostgreSQL (set DB_TYPE=postgresql to use)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ecosyntech
PG_USER=postgres
PG_PASSWORD=
PG_POOL_SIZE=20

# ====================
# AUTO-OPTIMIZED (No manual input needed)
# ====================

# These are auto-detected and optimized:
# OPS_SCHEDULER_INTERVAL - auto-set based on RAM
# OPS_HOT_RELOAD_ENABLED - defaults to false
# OPS_SCHEDULER_DISABLED - defaults to false

# ====================
# PERFORMANCE TUNING
# ====================

# For low-memory devices (< 1GB RAM), add:
# OPS_SCHEDULER_INTERVAL=3600000
# OPS_SCHEDULER_DISABLED=false

# ====================
# HEALTH REPORT SERVICE (WebLocal Integration)
# ====================

# WebLocal WebApp URL for health reports
WEBLOCAL_WEBAPP_URL=
WEBLOCAL_API_KEY=

# Optional: Customer ID for ESP32 firmware provisioning mapping
CUSTOMER_ID=
CLIENT_ID=default_client

# Report interval in minutes (default: 30)
HEALTH_REPORT_INTERVAL_MIN=30

# Queue threshold for alerts (default: 5)
HEALTH_REPORT_QUEUE_THRESHOLD=5

# Use HTTPS with certificate verification (default: false)
WEBLOCAL_USE_HTTPS=false

# ====================
# WATER OPTIMIZATION SERVICE
# ====================

# Enable/disable smart water optimization (default: false)
WATER_OPTIMIZATION_ENABLED=false

# Moisture thresholds (percentage)
WATER_MIN_MOISTURE=30
WATER_MAX_MOISTURE=70

# Check interval in ms (default: 300000 = 5 minutes)
WATER_CHECK_INTERVAL=300000

# ====================
# WEATHER API (Open-Meteo - free, no API key required)
# ====================

# Farm GPS coordinates for weather
FARM_LAT=10.7769
FARM_LON=106.7009

# ====================
# SECURITY & WEBHOOKS
# ====================
# IMPORTANT: Change these to random values in production!

HMAC_SECRET=CHANGE_ME_RANDOM
WEBHOOK_SECRET=CHANGE_ME_RANDOM
API_KEY=
SERVER_URL=http://localhost:3000
SESSION_TIMEOUT=1800
BASE_URL=https://ecosyntech.com

# ====================
# BLOCKCHAIN (Optional)
# ====================

BLOCKCHAIN_ENABLED=false
APTOS_NETWORK=testnet
APTOS_MODULE_ADDRESS=0x1
APTOS_PRIVATE_KEY=

# ====================
# AI ENGINE (Decision Support Layer)
# ====================

AI_ENGINE_ENABLED=true
AI_CONFIDENCE_THRESHOLD=0.6

# ====================
# MESSENGER INTEGRATION (Optional)
# ====================

MESSENGER_VERIFY_TOKEN=

# ====================
# QR CODE
# ====================

QR_CODE_ENABLED=true
QR_CODE_BASE_URL=https://ecosyntech.com

# ====================
# CORS
# ====================

# ⚠️ IMPORTANT: In production, list specific domains instead of *
# Format: https://example.com,https://app.example.com
# For development only, use *
CORS_ORIGIN=*
CORS_ALLOWED_ORIGINS=

# ====================
# RATE LIMITING
# ====================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ====================
# LOGGING
# ====================

LOG_LEVEL=info

# ====================
# BACKUP & RESTORE
# ====================

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# ====================
# PAYMENT GATEWAYS (VNPay, MoMo, SePay)
# ====================

# VNPay Configuration (https://vnpay.vn)
VNPAY_TMNCODE=
VNP_URL=https://sandbox.vnpayment.vn/payv2/vpcpay.html
VNPAY_API=https://sandbox.vnpayment.vn/apis/vnpay
VNPAY_RETURN_URL=https://ecosyntech.com/api/payment/vnpay-return

# MoMo Configuration (https://momo.vn)
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn
MOMO_REDIRECT_URL=https://ecosyntech.com/api/payment/momo-return

# SePay Configuration (https://sepay.vn)
SEPAY_PARTNER_ID=
SEPAY_PARTNER_KEY=
SEPAY_CHECKSUM_KEY=
SEPAY_API_URL=https://api.sepay.vn
SEPAY_DEFAULT_BANK=VCB
SEPAY_RETURN_URL=https://ecosyntech.com/api/payment/sepay-return
SEPAY_NOTIFY_URL=https://ecosyntech.com/api/payment/sepay-ipn