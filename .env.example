# ============================================
# EcoSynTech IoT Platform - Environment Configuration
# ============================================
# Copy this file to .env and configure your values

PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database
DB_PATH=./data/ecosyntech.db

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# HMAC Security (for ESP32 Webhooks)
HMAC_SECRET=CEOTAQUANGTHUAN_TADUYANH_CTYTNHHDUYANH_ECOSYNTECH_2026

# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================
# Get token from @BotFather on Telegram
# https://core.telegram.org/bots#creating-bot-tokens
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Comma-separated list of allowed chat IDs
# Get your chat ID from @userinfobot
# For groups, use the negative chat ID (e.g., -1001234567890)
TELEGRAM_ALLOWED_CHAT_IDS=12345678,-1001234567890

# Webhook URL (optional - leave empty for polling mode)
TELEGRAM_WEBHOOK_URL=

# ============================================
# MQTT BROKER
# ============================================
# Local broker (for development)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_PORT=1883
MQTT_WS_PORT=8080

# Or use HiveMQ Cloud (for production)
# MQTT_BROKER_URL=wss://broker.hivemq.com:8884/mqtt
# MQTT_USERNAME=your-username
# MQTT_PASSWORD=your-password

# ============================================
# API BASE URL (for Telegram bot)
# ============================================
API_BASE_URL=http://localhost:3000

# ============================================
# CORS
# ============================================
CORS_ORIGIN=*

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Webhooks
# ============================================
WEBHOOK_SECRET=your-webhook-secret

# ============================================
# Notifications (Optional)
# ============================================
TELEGRAM_NOTIFY_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=
SLACK_WEBHOOK_URL=
