# EcoSynTech IoT - Environment Configuration
# Copy to .env and configure

# ====================
# REQUIRED (Manual Input)
# ====================

# Server Configuration
PORT=3000
NODE_ENV=development

# Security (MUST CHANGE IN PRODUCTION)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_EXPIRES_IN=7d

# ====================
# OPTIONAL (Auto-configured)
# ====================

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# MQTT Broker (optional, will skip if empty)
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=

# InfluxDB (optional, will skip if empty)
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=

# Database
DB_TYPE=sqlite
DB_PATH=./data/ecosyntech.db

# PostgreSQL (set DB_TYPE=postgresql to use)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ecosyntech
PG_USER=postgres
PG_PASSWORD=
PG_POOL_SIZE=20

# ====================
# AUTO-OPTIMIZED (No manual input needed)
# ====================

# These are auto-detected and optimized:
# OPS_SCHEDULER_INTERVAL - auto-set based on RAM
# OPS_HOT_RELOAD_ENABLED - defaults to false
# OPS_SCHEDULER_DISABLED - defaults to false

# ====================
# PERFORMANCE TUNING
# ====================

# For low-memory devices (< 1GB RAM), add:
# OPS_SCHEDULER_INTERVAL=3600000
# OPS_SCHEDULER_DISABLED=false

# ====================
# HEALTH REPORT SERVICE (WebLocal Integration)
# ====================

# WebLocal WebApp URL for health reports
WEBLOCAL_WEBAPP_URL=
WEBLOCAL_API_KEY=

# Optional: Customer ID for ESP32 firmware provisioning mapping
CUSTOMER_ID=
CLIENT_ID=default_client

# Report interval in minutes (default: 30)
HEALTH_REPORT_INTERVAL_MIN=30

# Queue threshold for alerts (default: 5)
HEALTH_REPORT_QUEUE_THRESHOLD=5

# Use HTTPS with certificate verification (default: false)
WEBLOCAL_USE_HTTPS=false

# ====================
# WATER OPTIMIZATION SERVICE
# ====================

# Enable/disable smart water optimization (default: false)
WATER_OPTIMIZATION_ENABLED=false

# Moisture thresholds (percentage)
WATER_MIN_MOISTURE=30
WATER_MAX_MOISTURE=70

# Check interval in ms (default: 300000 = 5 minutes)
WATER_CHECK_INTERVAL=300000

# ====================
# WEATHER API (Open-Meteo - free, no API key required)
# ====================

# Farm GPS coordinates for weather
FARM_LAT=10.7769
FARM_LON=106.7009

# ====================
# SECURITY & WEBHOOKS
# ====================

HMAC_SECRET=CEOTAQUANGTHUAN_TADUYANH_CTYTNHHDUYANH_ECOSYNTECH_2026
WEBHOOK_SECRET=webhook-secret
API_KEY=
SERVER_URL=http://localhost:3000
BASE_URL=https://ecosyntech.com

# ====================
# BLOCKCHAIN (Optional)
# ====================

BLOCKCHAIN_ENABLED=false
APTOS_NETWORK=testnet
APTOS_MODULE_ADDRESS=0x1
APTOS_PRIVATE_KEY=

# ====================
# AI ENGINE (Decision Support Layer)
# ====================

AI_ENGINE_ENABLED=true
AI_CONFIDENCE_THRESHOLD=0.6

# ====================
# MESSENGER INTEGRATION (Optional)
# ====================

MESSENGER_VERIFY_TOKEN=

# ====================
# QR CODE
# ====================

QR_CODE_ENABLED=true
QR_CODE_BASE_URL=https://ecosyntech.com

# ====================
# CORS
# ====================

CORS_ORIGIN=*

# ====================
# RATE LIMITING
# ====================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ====================
# LOGGING
# ====================

LOG_LEVEL=info

# ====================
# BACKUP & RESTORE
# ====================

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30