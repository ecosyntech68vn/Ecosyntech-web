{
  "name": "ecosyntech-iot-backend",
  "version": "5.0.0",
  "description": "EcoSynTech IoT Backend - Optimized for low-memory devices",
  "main": "server.js",

  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:lowmem": "node --max-old-space-size=256 server.js",
    "test": "jest --passWithNoTests --forceExit --detectOpenHandles",
    "lint": "eslint src/",
    "build": "node --check server.js"
  },

  "keywords": [
    "iot",
    "agriculture",
    "smart-farming",
    "mqtt",
    "websocket",
    "rest-api",
    "low-memory"
  ],

  "author": "EcoSynTech",
  "license": "MIT",

  "engines": {
    "node": ">=18.0.0"
  },

  "dependencies": {
    "aedes": "^0.51.3",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.12.1",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.3.0",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4",
    "sql.js": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "websocket-stream": "^5.5.2",
    "winston": "^3.11.0",
    "ws": "^8.16.0",
    "systeminformation": "^5.21.20",
    "axios": "^1.6.5",
    "pg": "^8.11.3"
  },

  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },

  "optimization": {
    "nodeOptions": "--max-old-space-size=384 --optimize-for-size --gc-interval=100",
    "minRAM": "512MB",
    "recommendedRAM": "1GB",
    "Win7Compatible": true
  }
}