{
  "name": "ecosyntech-iot-backend",
  "version": "5.0.0",
  "description": "EcoSynTech IoT Backend - Optimized for low-memory devices",
  "main": "server.js",
  "scripts": {
      "setup-models": "./scripts/setup-models.sh",
      "start": "node server.js",
      "dev": "nodemon server.js",
      "start:lowmem": "node --max-old-space-size=256 server.js",
      "test": "jest --passWithNoTests --forceExit --detectOpenHandles",
      "test:coverage": "jest --coverage --passWithNoTests --forceExit --detectOpenHandles",
      "test:dashboard": "jest --runInBand __tests__/dashboard_endpoints.test.js",
      "test:e2e": "NODE_ENV=test npx jest __tests__/e2e.api.flow.test.js --runInBand --forceExit",
      "lint": "eslint src/",
      "lint:fix": "eslint src/ --fix",
      "typecheck": "tsc --noEmit",
      "audit": "npm audit --production",
    "audit:fix": "npm audit fix --production",
    "build": "node --check server.js",
    "bootstrap-ai": "node bin/bootstrap-ai.js",
    "validate-skills": "node scripts/validate-skills.js"
  },
  "validate-skills": "node scripts/validate-skills.js",
  "bin": {
    "bootstrap-ai": "bin/bootstrap-ai.js"
  },
  "keywords": [
    "iot",
    "agriculture",
    "smart-farming",
    "mqtt",
    "websocket",
    "rest-api",
    "low-memory"
  ],
  "author": "EcoSynTech",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@tensorflow/tfjs-node": "^4.22.0",
    "aedes": "^0.51.3",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "bonjour": "^3.5.1",
    "chart.js": "^4.4.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.12.1",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.3.0",
    "onnxruntime-node": "^1.24.3",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "sql.js": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "systeminformation": "^5.21.20",
    "uuid": "^9.0.1",
    "websocket-stream": "^5.5.2",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "typescript": "^6.0.3"
  },
  "optimization": {
    "nodeOptions": "--max-old-space-size=384 --optimize-for-size --gc-interval=100",
    "minRAM": "512MB",
    "recommendedRAM": "1GB",
    "Win7Compatible": true
  }
}
